{
  "manifest_version": 3,
  "name": "MangaDotNet",
  "version": "0.1.0",
  "description": "Detect MangaDotNet pages, browse chapters, and download manga from the active browser session.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "MangaDotNet",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "permissions": ["activeTab", "storage", "downloads", "tabs", "scripting", "alarms"],
  "host_permissions": ["https://mangadot.net/*"],
  "content_scripts": [
    {
      "matches": ["https://mangadot.net/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
